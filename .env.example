# ============================================================
# Zipsa Demo — Environment Variables
# ============================================================
# NOTE: This demo uses OpenRouter for BOTH local and external LLM.
# In a real deployment, LOCAL_HOST should point to your own
# self-hosted LLM (Ollama, vLLM, etc.) inside your trust zone.
# ============================================================

# OpenRouter API key (used for both local + external routing)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# "Local" LLM — fast model simulating trust-zone behavior (demo only)
# In production: replace with your own Ollama or self-hosted LLM
LOCAL_HOST=https://openrouter.ai/api/v1
LOCAL_API_KEY=your-openrouter-key
LOCAL_MODEL=qwen/qwen3.5-27b

# External LLM — high-capability model for complex domain reasoning
EXTERNAL_PROVIDER=openai
EXTERNAL_MODEL=anthropic/claude-sonnet-4-5
OPENAI_API_KEY=your-openrouter-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Admin dashboard protection
ADMIN_TOKEN=change-me-please

# Demo settings
DEMO_MODE=true
LOG_DIR=logs
